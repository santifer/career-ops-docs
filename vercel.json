{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "career-ops.dev" }],
      "destination": "https://career-ops.org/:path*",
      "permanent": true
    },
    {
      "source": "/community",
      "destination": "https://discord.gg/8pRpHETxa4",
      "permanent": false
    },
    {
      "source": "/repo",
      "destination": "https://github.com/santifer/career-ops",
      "permanent": true
    },
    {
      "source": "/twitter",
      "destination": "https://x.com/santifer",
      "permanent": true
    },
    {
      "source": "/sponsors",
      "destination": "/sustain",
      "permanent": true
    },
    {
      "source": "/use-cases",
      "destination": "/docs/reference/modes",
      "permanent": true
    },
    {
      "source": "/use-cases/mode-:slug",
      "destination": "/docs/reference/modes/:slug",
      "permanent": true
    },
    {
      "source": "/use-cases/portal-:slug",
      "destination": "/docs/reference/portals/:slug",
      "permanent": true
    }
  ]
}
